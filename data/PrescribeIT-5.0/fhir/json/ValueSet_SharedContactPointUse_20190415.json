          "display": "Definition"
        },
        "value": "A communication contact point at a home; attempted contacts for business purposes might intrude privacy and chances are one will contact family or other household members instead of the person one wishes to call. Typically used with urgent cases, or if no other contacts are available."
      }, {
        "language": "en",
        "use": {
          "system": "http://snomed.info/sct",
          "code": "900000000000013009",
          "display": "Synonym"
        },
        "value": "Home"
      }, {
